{
  "name": "codelore",
  "displayName": "CodeLore",
  "description": "Persistent context for Claude Code, Cursor, and Copilot. Capture decisions, gotchas, and critical regions as AI agents modify your codebase — so knowledge survives across PRs and teammates.",
  "version": "0.2.3",
  "publisher": "jmpdevelopment",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmpdevelopment/codelore.git"
  },
  "bugs": {
    "url": "https://github.com/jmpdevelopment/codelore/issues"
  },
  "homepage": "https://github.com/jmpdevelopment/codelore#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "ai",
    "claude",
    "claude code",
    "copilot",
    "cursor",
    "agents",
    "agents.md",
    "context",
    "documentation",
    "annotations",
    "knowledge",
    "codebase"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codelore.addAnnotation",
        "title": "CodeLore: Add Annotation",
        "icon": "$(note)"
      },
      {
        "command": "codelore.editAnnotation",
        "title": "CodeLore: Edit Annotation",
        "icon": "$(edit)"
      },
      {
        "command": "codelore.deleteAnnotation",
        "title": "CodeLore: Delete Annotation",
        "icon": "$(trash)"
      },
      {
        "command": "codelore.verifyAnnotation",
        "title": "CodeLore: Verify AI Annotation",
        "icon": "$(verified)"
      },
      {
        "command": "codelore.markCritical",
        "title": "CodeLore: Mark as Critical",
        "icon": "$(shield)"
      },
      {
        "command": "codelore.manageComponentsForFile",
        "title": "CodeLore: Manage Components for File",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "codelore.editComponent",
        "title": "CodeLore: Edit Component",
        "icon": "$(edit)"
      },
      {
        "command": "codelore.filter",
        "title": "CodeLore: Filter",
        "icon": "$(filter)"
      },
      {
        "command": "codelore.refreshSidebar",
        "title": "CodeLore: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codelore.scanFile",
        "title": "CodeLore: Scan Current File",
        "icon": "$(sparkle)"
      },
      {
        "command": "codelore.scanComponent",
        "title": "CodeLore: Scan Component",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "codelore.scanProject",
        "title": "CodeLore: Scan Project",
        "icon": "$(globe)"
      },
      {
        "command": "codelore.proposeComponent",
        "title": "CodeLore: Propose Components (AI)",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "codelore.changeModel",
        "title": "CodeLore: Change AI Model"
      },
      {
        "command": "codelore.searchAnnotations",
        "title": "CodeLore: Search Annotations",
        "icon": "$(search)"
      },
      {
        "command": "codelore.resolveCritical",
        "title": "CodeLore: Resolve Critical Flag",
        "icon": "$(check)"
      },
      {
        "command": "codelore.removeCritical",
        "title": "CodeLore: Remove Critical Flag",
        "icon": "$(trash)"
      },
      {
        "command": "codelore.quickNote",
        "title": "CodeLore: Quick Note",
        "icon": "$(comment)"
      },
      {
        "command": "codelore.copyAnnotationsForFile",
        "title": "CodeLore: Copy Annotations for Current File",
        "icon": "$(copy)"
      },
      {
        "command": "codelore.generateAgentInstructions",
        "title": "CodeLore: Generate Agent Instruction Files",
        "icon": "$(file-code)"
      },
      {
        "command": "codelore.checkAnchors",
        "title": "CodeLore: Check Annotation Anchors",
        "icon": "$(pin)"
      }
    ],
    "keybindings": [
      {
        "command": "codelore.addAnnotation",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      },
      {
        "command": "codelore.quickNote",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j",
        "when": "editorTextFocus"
      },
      {
        "command": "codelore.scanFile",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "codelore.submenu",
          "group": "codelore@1"
        }
      ],
      "codelore.submenu": [
        {
          "command": "codelore.addAnnotation",
          "group": "annotation@1"
        },
        {
          "command": "codelore.quickNote",
          "group": "annotation@2"
        },
        {
          "command": "codelore.markCritical",
          "group": "critical@1"
        },
        {
          "command": "codelore.scanFile",
          "group": "ai@1"
        }
      ],
      "view/title": [
        {
          "command": "codelore.filter",
          "when": "view == codelore.changePlan || view == codelore.criticalQueue",
          "group": "navigation@2"
        },
        {
          "command": "codelore.checkAnchors",
          "when": "view == codelore.changePlan",
          "group": "navigation@3"
        },
        {
          "command": "codelore.generateAgentInstructions",
          "when": "view == codelore.changePlan || view == codelore.components",
          "group": "navigation@4"
        },
        {
          "command": "codelore.manageComponentsForFile",
          "when": "view == codelore.components",
          "group": "navigation@1"
        },
        {
          "command": "codelore.proposeComponent",
          "when": "view == codelore.components",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "codelore.editComponent",
          "when": "view == codelore.components && viewItem == component",
          "group": "inline@1"
        },
        {
          "command": "codelore.verifyAnnotation",
          "when": "view == codelore.changePlan && viewItem == annotation-ai-generated",
          "group": "inline@0"
        },
        {
          "command": "codelore.editAnnotation",
          "when": "view == codelore.changePlan && viewItem =~ /^annotation/",
          "group": "inline@1"
        },
        {
          "command": "codelore.deleteAnnotation",
          "when": "view == codelore.changePlan && viewItem =~ /^annotation/",
          "group": "inline@2"
        },
        {
          "command": "codelore.resolveCritical",
          "when": "view == codelore.criticalQueue && viewItem == criticalFlag",
          "group": "inline@1"
        },
        {
          "command": "codelore.removeCritical",
          "when": "view == codelore.criticalQueue && viewItem == criticalFlag",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "codelore.editAnnotation",
          "when": "false"
        },
        {
          "command": "codelore.deleteAnnotation",
          "when": "false"
        },
        {
          "command": "codelore.editComponent",
          "when": "false"
        },
        {
          "command": "codelore.verifyAnnotation",
          "when": "false"
        },
        {
          "command": "codelore.resolveCritical",
          "when": "false"
        },
        {
          "command": "codelore.removeCritical",
          "when": "false"
        }
      ]
    },
    "submenus": [
      {
        "id": "codelore.submenu",
        "label": "CodeLore"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codelore-sidebar",
          "title": "CodeLore",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "codelore-sidebar": [
        {
          "id": "codelore.components",
          "name": "Components"
        },
        {
          "id": "codelore.changePlan",
          "name": "Annotations"
        },
        {
          "id": "codelore.criticalQueue",
          "name": "Critical Review Queue"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codelore.components",
        "contents": "No components defined yet. Components group related files into subsystems so annotations can be scanned and browsed by area.\n[Propose Components (AI)](command:codelore.proposeComponent)\n[Scan Project](command:codelore.scanProject)\nOr tag the active file manually:\n[Manage Components for File](command:codelore.manageComponentsForFile)"
      },
      {
        "view": "codelore.changePlan",
        "contents": "No annotations yet. Capture what you learn about the code \u2014 decisions, gotchas, constraints \u2014 so it survives turnover and feeds AI agents.\n[Add Annotation](command:codelore.addAnnotation)\n[Scan Current File](command:codelore.scanFile)\nWire your AI agents to read annotations as context:\n[Generate Agent Instruction Files](command:codelore.generateAgentInstructions)"
      },
      {
        "view": "codelore.criticalQueue",
        "contents": "No critical flags. Use Mark as Critical on a risky region to track it here, or let Scan Current File propose flags from code."
      }
    ],
    "configuration": {
      "title": "CodeLore",
      "properties": {
        "codelore.storagePath": {
          "type": "string",
          "default": ".vscode/codelore.yaml",
          "description": "Path to the CodeLore storage file (relative to workspace root)."
        },
        "codelore.defaultScope": {
          "type": "string",
          "enum": [
            "shared",
            "personal"
          ],
          "default": "shared",
          "description": "Default scope for new annotations and review markers. 'shared' commits to .codelore/ (visible to team), 'personal' stays in .vscode/ (just for you)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "~1.95.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "uuid": "^13.0.0"
  }
}
