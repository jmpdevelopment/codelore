{
  "name": "codediary",
  "displayName": "CodeDiary",
  "description": "Institutional knowledge capture for large codebases undergoing AI-accelerated development. Annotate, review, and build shared understanding as AI agents modify your code.",
  "version": "0.1.0",
  "publisher": "codediary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/codediary/codediary.git"
  },
  "bugs": {
    "url": "https://github.com/codediary/codediary/issues"
  },
  "homepage": "https://github.com/codediary/codediary#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "code knowledge",
    "AI code review",
    "code annotation",
    "legacy codebase",
    "institutional knowledge",
    "code documentation",
    "AI development",
    "team knowledge sharing",
    "code diary"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codediary.addAnnotation",
        "title": "CodeDiary: Add Annotation",
        "icon": "$(note)"
      },
      {
        "command": "codediary.editAnnotation",
        "title": "CodeDiary: Edit Annotation",
        "icon": "$(edit)"
      },
      {
        "command": "codediary.deleteAnnotation",
        "title": "CodeDiary: Delete Annotation",
        "icon": "$(trash)"
      },
      {
        "command": "codediary.verifyAnnotation",
        "title": "CodeDiary: Verify AI Annotation",
        "icon": "$(verified)"
      },
      {
        "command": "codediary.markCritical",
        "title": "CodeDiary: Mark as Critical",
        "icon": "$(shield)"
      },
      {
        "command": "codediary.clearAll",
        "title": "CodeDiary: Clear Personal Data"
      },
      {
        "command": "codediary.manageComponentsForFile",
        "title": "CodeDiary: Manage Components for File",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "codediary.editComponent",
        "title": "CodeDiary: Edit Component",
        "icon": "$(edit)"
      },
      {
        "command": "codediary.filter",
        "title": "CodeDiary: Filter",
        "icon": "$(filter)"
      },
      {
        "command": "codediary.refreshSidebar",
        "title": "CodeDiary: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codediary.scanFile",
        "title": "CodeDiary: Scan Current File (Knowledge + Critical)",
        "icon": "$(sparkle)"
      },
      {
        "command": "codediary.scanComponent",
        "title": "CodeDiary: Scan Component (Knowledge + Critical)",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "codediary.scanProject",
        "title": "CodeDiary: Scan Entire Project (Knowledge + Critical)",
        "icon": "$(globe)"
      },
      {
        "command": "codediary.proposeComponent",
        "title": "CodeDiary: Propose Components (AI)",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "codediary.changeModel",
        "title": "CodeDiary: Change AI Model"
      },
      {
        "command": "codediary.searchAnnotations",
        "title": "CodeDiary: Search Annotations",
        "icon": "$(search)"
      },
      {
        "command": "codediary.resolveCritical",
        "title": "CodeDiary: Resolve Critical Flag",
        "icon": "$(check)"
      },
      {
        "command": "codediary.removeCritical",
        "title": "CodeDiary: Remove Critical Flag",
        "icon": "$(trash)"
      },
      {
        "command": "codediary.quickNote",
        "title": "CodeDiary: Quick AI Note (Ephemeral)",
        "icon": "$(robot)"
      },
      {
        "command": "codediary.copyAnnotationsForFile",
        "title": "CodeDiary: Copy Annotations for Current File",
        "icon": "$(copy)"
      },
      {
        "command": "codediary.generateAgentInstructions",
        "title": "CodeDiary: Generate Agent Instruction Files",
        "icon": "$(file-code)"
      },
      {
        "command": "codediary.checkAnchors",
        "title": "CodeDiary: Check Annotation Anchors",
        "icon": "$(pin)"
      },
      {
        "command": "codediary.showPreCommitBrief",
        "title": "CodeDiary: Show Pre-Commit Brief",
        "icon": "$(checklist)"
      }
    ],
    "keybindings": [
      {
        "command": "codediary.addAnnotation",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j",
        "when": "editorTextFocus"
      },
      {
        "command": "codediary.quickNote",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      },
      {
        "command": "codediary.showPreCommitBrief",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b"
      },
      {
        "command": "codediary.scanFile",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "codediary.submenu",
          "group": "codediary@1"
        }
      ],
      "codediary.submenu": [
        {
          "command": "codediary.addAnnotation",
          "group": "annotation@1"
        },
        {
          "command": "codediary.markCritical",
          "group": "critical@1"
        },
        {
          "command": "codediary.scanFile",
          "group": "ai@1"
        },
        {
          "command": "codediary.resolveCritical",
          "group": "critical@2"
        },
        {
          "command": "codediary.removeCritical",
          "group": "critical@3"
        },
        {
          "command": "codediary.quickNote",
          "group": "annotation@2"
        },
        {
          "command": "codediary.copyAnnotationsForFile",
          "group": "annotation@3"
        }
      ],
      "view/title": [
        {
          "command": "codediary.filter",
          "when": "view == codediary.changePlan || view == codediary.criticalQueue",
          "group": "navigation@2"
        },
        {
          "command": "codediary.refreshSidebar",
          "when": "view == codediary.changePlan || view == codediary.criticalQueue || view == codediary.preCommitBrief || view == codediary.components",
          "group": "navigation@5"
        },
        {
          "command": "codediary.manageComponentsForFile",
          "when": "view == codediary.components",
          "group": "navigation@1"
        },
        {
          "command": "codediary.proposeComponent",
          "when": "view == codediary.components",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "codediary.editComponent",
          "when": "view == codediary.components && viewItem == component",
          "group": "inline@1"
        },
        {
          "command": "codediary.verifyAnnotation",
          "when": "view == codediary.changePlan && viewItem == annotation-ai-generated",
          "group": "inline@0"
        },
        {
          "command": "codediary.editAnnotation",
          "when": "view == codediary.changePlan && viewItem =~ /^annotation/",
          "group": "inline@1"
        },
        {
          "command": "codediary.deleteAnnotation",
          "when": "view == codediary.changePlan && viewItem =~ /^annotation/",
          "group": "inline@2"
        },
        {
          "command": "codediary.resolveCritical",
          "when": "view == codediary.criticalQueue && viewItem == criticalFlag",
          "group": "inline@1"
        },
        {
          "command": "codediary.removeCritical",
          "when": "view == codediary.criticalQueue && viewItem == criticalFlag",
          "group": "inline@2"
        }
      ],
      "commandPalette": [
        {
          "command": "codediary.refreshSidebar",
          "when": "false"
        },
        {
          "command": "codediary.editAnnotation",
          "when": "false"
        },
        {
          "command": "codediary.deleteAnnotation",
          "when": "false"
        },
        {
          "command": "codediary.editComponent",
          "when": "false"
        },
        {
          "command": "codediary.verifyAnnotation",
          "when": "false"
        },
        {
          "command": "codediary.resolveCritical",
          "when": "false"
        },
        {
          "command": "codediary.removeCritical",
          "when": "false"
        }
      ]
    },
    "submenus": [
      {
        "id": "codediary.submenu",
        "label": "CodeDiary"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codediary-sidebar",
          "title": "CodeDiary",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "codediary-sidebar": [
        {
          "id": "codediary.components",
          "name": "Components"
        },
        {
          "id": "codediary.changePlan",
          "name": "Annotations",
          "visibility": "collapsed"
        },
        {
          "id": "codediary.preCommitBrief",
          "name": "Pre-Commit Brief"
        },
        {
          "id": "codediary.criticalQueue",
          "name": "Critical Review Queue"
        }
      ]
    },
    "configuration": {
      "title": "CodeDiary",
      "properties": {
        "codediary.storagePath": {
          "type": "string",
          "default": ".vscode/codediary.yaml",
          "description": "Path to the CodeDiary storage file (relative to workspace root)."
        },
        "codediary.defaultScope": {
          "type": "string",
          "enum": [
            "shared",
            "personal"
          ],
          "default": "shared",
          "description": "Default scope for new annotations and review markers. 'shared' commits to .codediary/ (visible to team), 'personal' stays in .vscode/ (just for you)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.110.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "uuid": "^13.0.0"
  }
}
