{
  "name": "codediary",
  "displayName": "CodeDiary",
  "description": "Institutional knowledge capture for large codebases undergoing AI-accelerated development. Annotate, review, and build shared understanding as AI agents modify your code.",
  "version": "0.1.0",
  "publisher": "codediary",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "code knowledge",
    "AI code review",
    "code annotation",
    "legacy codebase",
    "institutional knowledge",
    "code documentation",
    "AI development",
    "team knowledge sharing",
    "code diary"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codediary.addAnnotation",
        "title": "CodeDiary: Add Annotation",
        "icon": "$(note)"
      },
      {
        "command": "codediary.editAnnotation",
        "title": "CodeDiary: Edit Annotation"
      },
      {
        "command": "codediary.deleteAnnotation",
        "title": "CodeDiary: Delete Annotation"
      },
      {
        "command": "codediary.markReviewed",
        "title": "CodeDiary: Mark as Reviewed",
        "icon": "$(check)"
      },
      {
        "command": "codediary.markFileReviewed",
        "title": "CodeDiary: Mark File as Reviewed"
      },
      {
        "command": "codediary.unmarkReviewed",
        "title": "CodeDiary: Unmark Reviewed"
      },
      {
        "command": "codediary.markCritical",
        "title": "CodeDiary: Mark as Critical",
        "icon": "$(shield)"
      },
      {
        "command": "codediary.clearAll",
        "title": "CodeDiary: Clear Personal Data"
      },
      {
        "command": "codediary.setNarrative",
        "title": "CodeDiary: Set Change Narrative"
      },
      {
        "command": "codediary.filterByCategory",
        "title": "CodeDiary: Filter by Category",
        "icon": "$(filter)"
      },
      {
        "command": "codediary.refreshSidebar",
        "title": "CodeDiary: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "codediary.suggestDiary",
        "title": "CodeDiary: Suggest Diary Entries (Current File)",
        "icon": "$(sparkle)"
      },
      {
        "command": "codediary.suggestDiaryAll",
        "title": "CodeDiary: Suggest Diary Entries (All Changes)",
        "icon": "$(sparkle)"
      },
      {
        "command": "codediary.scanCritical",
        "title": "CodeDiary: Scan Changes for Critical Logic (Diff Only)",
        "icon": "$(shield)"
      },
      {
        "command": "codediary.scanCriticalAll",
        "title": "CodeDiary: Scan All Uncommitted Changes for Critical Logic (Diff Only)",
        "icon": "$(shield)"
      },
      {
        "command": "codediary.scanFile",
        "title": "CodeDiary: Scan Entire File for Critical Logic (Full File)",
        "icon": "$(shield)"
      },
      {
        "command": "codediary.changeModel",
        "title": "CodeDiary: Change AI Model"
      },
      {
        "command": "codediary.searchAnnotations",
        "title": "CodeDiary: Search Annotations",
        "icon": "$(search)"
      },
      {
        "command": "codediary.filterByPath",
        "title": "CodeDiary: Filter by File/Folder Path",
        "icon": "$(folder)"
      },
      {
        "command": "codediary.filterBySeverity",
        "title": "CodeDiary: Filter Critical by Severity",
        "icon": "$(shield)"
      },
      {
        "command": "codediary.clearFilters",
        "title": "CodeDiary: Clear All Filters",
        "icon": "$(clear-all)"
      },
      {
        "command": "codediary.resolveCritical",
        "title": "CodeDiary: Resolve Critical Flag",
        "icon": "$(check)"
      },
      {
        "command": "codediary.removeCritical",
        "title": "CodeDiary: Remove Critical Flag",
        "icon": "$(trash)"
      },
      {
        "command": "codediary.quickNote",
        "title": "CodeDiary: Quick AI Note (Ephemeral)",
        "icon": "$(robot)"
      },
      {
        "command": "codediary.copyAnnotationsForFile",
        "title": "CodeDiary: Copy Annotations for Current File",
        "icon": "$(copy)"
      },
      {
        "command": "codediary.generateAgentInstructions",
        "title": "CodeDiary: Generate Agent Instruction Files",
        "icon": "$(file-code)"
      },
      {
        "command": "codediary.reanchor",
        "title": "CodeDiary: Re-anchor Stale Annotations",
        "icon": "$(pin)"
      },
      {
        "command": "codediary.verifyAnchors",
        "title": "CodeDiary: Verify Annotation Anchors",
        "icon": "$(verified)"
      }
    ],
    "keybindings": [
      {
        "command": "codediary.addAnnotation",
        "key": "ctrl+shift+j",
        "mac": "cmd+shift+j",
        "when": "editorTextFocus"
      },
      {
        "command": "codediary.markReviewed",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      },
      {
        "command": "codediary.quickNote",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "codediary.submenu",
          "group": "codediary@1"
        }
      ],
      "codediary.submenu": [
        {
          "command": "codediary.addAnnotation",
          "group": "annotation@1"
        },
        {
          "command": "codediary.markReviewed",
          "group": "review@1"
        },
        {
          "command": "codediary.unmarkReviewed",
          "group": "review@2"
        },
        {
          "command": "codediary.markCritical",
          "group": "critical@1"
        },
        {
          "command": "codediary.suggestDiary",
          "group": "ai@1"
        },
        {
          "command": "codediary.scanCritical",
          "group": "ai@2"
        },
        {
          "command": "codediary.scanFile",
          "group": "ai@3"
        },
        {
          "command": "codediary.resolveCritical",
          "group": "critical@2"
        },
        {
          "command": "codediary.removeCritical",
          "group": "critical@3"
        },
        {
          "command": "codediary.quickNote",
          "group": "annotation@2"
        },
        {
          "command": "codediary.copyAnnotationsForFile",
          "group": "annotation@3"
        }
      ],
      "view/title": [
        {
          "command": "codediary.filterByCategory",
          "when": "view == codediary.changePlan",
          "group": "navigation@2"
        },
        {
          "command": "codediary.filterByPath",
          "when": "view == codediary.changePlan || view == codediary.criticalQueue",
          "group": "navigation@3"
        },
        {
          "command": "codediary.filterBySeverity",
          "when": "view == codediary.criticalQueue",
          "group": "navigation@2"
        },
        {
          "command": "codediary.clearFilters",
          "when": "view == codediary.changePlan || view == codediary.criticalQueue",
          "group": "navigation@4"
        },
        {
          "command": "codediary.refreshSidebar",
          "when": "view == codediary.changePlan || view == codediary.criticalQueue",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "codediary.editAnnotation",
          "when": "view == codediary.changePlan && viewItem == annotation",
          "group": "inline@1"
        },
        {
          "command": "codediary.deleteAnnotation",
          "when": "view == codediary.changePlan && viewItem == annotation",
          "group": "inline@2"
        },
        {
          "command": "codediary.resolveCritical",
          "when": "view == codediary.criticalQueue && viewItem == criticalFlag",
          "group": "inline@1"
        },
        {
          "command": "codediary.removeCritical",
          "when": "view == codediary.criticalQueue && viewItem == criticalFlag",
          "group": "inline@2"
        }
      ]
    },
    "submenus": [
      {
        "id": "codediary.submenu",
        "label": "CodeDiary"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codediary-sidebar",
          "title": "CodeDiary",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "codediary-sidebar": [
        {
          "id": "codediary.changePlan",
          "name": "Change Plan"
        },
        {
          "id": "codediary.criticalQueue",
          "name": "Critical Review Queue"
        }
      ]
    },
    "configuration": {
      "title": "CodeDiary",
      "properties": {
        "codediary.storagePath": {
          "type": "string",
          "default": ".vscode/codediary.yaml",
          "description": "Path to the CodeDiary storage file (relative to workspace root)."
        },
        "codediary.defaultScope": {
          "type": "string",
          "enum": [
            "shared",
            "personal"
          ],
          "default": "shared",
          "description": "Default scope for new annotations and review markers. 'shared' commits to .codediary/ (visible to team), 'personal' stays in .vscode/ (just for you)."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.110.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "uuid": "^13.0.0"
  }
}
